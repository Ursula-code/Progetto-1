# Esercizio Punto 3
def crea_lista():
    #Chiedo all'utente di inserire un numero intero 
    numero = int(input("Scrivere un numero:"))
    #Inizializza la lista inserendo come primo elemento il numero scelto 
    lista = [numero]

    #il ciclo continua finchè l'ultimo elemento non è 1 oppure finchè la lista è < 100
    while lista[-1] != 1 and len(lista)<100 :
        #Recupera l'ultimmo elemento inserito nella lista 
        ultimo_numero = lista[-1]

        # Controlla se l'ultimo numero è pari 
        if ultimo_numero%2 == 0 :
            #Se è pari, lo divide per 2
            nuovo = ultimo_numero / 2
            lista.append(nuovo)
        else:
            #Se è dispari, lo moltiplica per 3 e aggiunge 1
            nuovo = (ultimo_numero*3)+1
            lista.append(nuovo)
    
    # Quando il ciclo finisce restituice la lista completa della sequenza
    return lista



