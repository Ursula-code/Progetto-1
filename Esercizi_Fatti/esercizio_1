#Esercizio Punto 4
def analizza_sequenza(lista):
    massimo = lista[0]
    risultato_finale = lista[0]
    for n in lista:
         if n > massimo:
            massimo = n 
            risultato_finale = n
    lunghezza = len(lista) 
    totale_somma = 0
    for i in lista:
        totale_somma += i  
    valori = [risultato_finale, lunghezza, totale_somma]
    return (valori)
        

