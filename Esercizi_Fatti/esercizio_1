#Esercizio Punto 4
def analizza_sequenza(lista):
    # Inizializzo le variabili pe il valore massimo usando il primo elemento della lista
    massimo = lista[0]
    risultato_finale = lista[0]

    # il ciclo scorre ogni numero nella lista 
    for n in lista:
        
        # se il numero corrente è maggiore del massimo allora: 
         if n > massimo:
            massimo = n                     #Aggiorna il valore numerico del massimo                   
            risultato_finale = n            #Salva il numero come risultato finale 
    
    # Calcola quanti elementi ci sono nella lista 
    lunghezza = len(lista) 
    
    #Calcola la somma di tutti gli elementi della lista 
    totale_somma = 0
    for i in lista:
        totale_somma += i 

    # Crea una lista contenente i tre valori calcolati  
    valori = [risultato_finale, lunghezza, totale_somma]
    #restituisce la lista con i dati 
    return (valori)
        

