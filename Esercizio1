"""Punto 2"""
def chiedi_numero ():
    while True:
        scelta = input("Inserisci numero:")
        numero = int(scelta)
        if numero > 0:
            return numero 
        else:
            print("Errore: il numero deve essere positivo, riprova!")

risultato = chiedi_numero ()
print(risultato )